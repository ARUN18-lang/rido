NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://arunkumar@localhost:5432/rido?schema=public

REDIS_URL=redis://localhost:6379
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d
JWT_OLD_ACCESS_SECRET=
JWT_OLD_REFRESH_SECRET=

MSG91_API_KEY=
MSG91_SENDER_ID=RIDO
MSG91_OTP_TEMPLATE_ID=

GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_DIRECTIONS_URL=https://maps.googleapis.com/maps/api/directions/json
GOOGLE_MAPS_DISTANCE_MATRIX_URL=https://maps.googleapis.com/maps/api/distancematrix/json

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=

SENTRY_DSN=

CORS_ORIGINS=http://localhost:3000,http://localhost:8081

PLATFORM_COMMISSION_PERCENT=10
POOL_MATCH_WINDOW_SECONDS=300
POOL_MATCH_RADIUS_KM=3
POOL_ROUTE_OVERLAP_THRESHOLD=65
DRIVER_SEARCH_RADIUS_KM=5
DRIVER_ACCEPT_TIMEOUT_SECONDS=20
RIDE_CANCEL_FREE_WINDOW_MINUTES=2
ROUTE_DEVIATION_THRESHOLD_METERS=500
RIDE_SEARCH_TIMEOUT_MINUTES=15

# Dynamic Pricing & Surge Engine Config
OPENWEATHER_API_KEY=
SURGE_RECOMPUTE_INTERVAL_SECONDS=60
SURGE_ACTIVATION_THRESHOLD=0.15
SURGE_WEIGHT_DEMAND_SUPPLY=0.45
SURGE_WEIGHT_WEATHER=0.20
SURGE_WEIGHT_TRAFFIC=0.20
SURGE_WEIGHT_EVENT=0.15
SURGE_EMA_SMOOTHING_FACTOR=0.3

# Cache TTLs
ROUTE_CACHE_TTL_SECONDS=180
SURGE_CACHE_TTL_SECONDS=90
WEATHER_CACHE_TTL_SECONDS=900

# Fare and Pooling Pricing Defaults
DEFAULT_PER_STOP_CHARGE=8
DEFAULT_WAITING_CHARGE_PER_MIN=2
FREE_WAIT_MINUTES_PER_STOP=2
ROUTE_ONLY_TOLERANCE_METERS=150

# =========================================================================
# DOCKER-COMPOSE CONFIGURATION NOTES
# =========================================================================
# When running the backend via docker-compose:
# 1. DATABASE_URL and REDIS_URL will use container hostnames ("postgres" and "redis")
#    which are automatically injected by docker-compose environment configurations.
# 2. If you are running tests or scripts locally on your host machine, you will still
#    need to point DATABASE_URL and REDIS_URL to "localhost" as shown below:
#      DATABASE_URL=postgresql://rido_dev:rido_dev_pass@localhost:5432/rido_db?schema=public
#      REDIS_URL=redis://localhost:6379
# 3. For physical mobile devices / emulators to connect to the backend, find your host
#    IP (e.g. macOS command: "ipconfig getifaddr en0") and set your mobile app base URL to:
#      http://<YOUR_LAN_IP>:3000
# =========================================================================
